# Prayer Profiles — Environment Variables
# Copy this file to .env and fill in real values before running in production.
# NEVER commit your .env file to git.

# ── Required ──────────────────────────────────────────────────────────────────

# JWT signing secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# Invite code required to create new accounts.
# Share this only with people you want to be able to register.
INVITE_CODE=your-secret-invite-code

# ── Optional ──────────────────────────────────────────────────────────────────

# Port the server listens on (default: 3001)
# PORT=3001

# Directory for storing profiles.json and uploads/ (default: project root)
# DATA_DIR=/data
