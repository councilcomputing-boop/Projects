# Copy this file to .env and fill in your values.
# Never commit .env to GitHub — it contains passwords.

# Flask secret key — generate one at: https://djecrety.ir/
SECRET_KEY=replace-with-a-long-random-string

# Database — leave blank to use SQLite locally.
# On Railway this is set automatically when you add a PostgreSQL plugin.
DATABASE_URL=

# Email (Gmail recommended)
# 1. Create or use a Gmail account for sending notifications
# 2. Enable 2-Factor Authentication on that Gmail account
# 3. Go to: Google Account > Security > App Passwords
# 4. Create an App Password for "Mail" and paste it below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-character-app-password

# Who receives email notifications (comma-separated for multiple people)
NOTIFY_TO=you@yourcompany.com,colleague@yourcompany.com

# The public URL of your app (used in email links)
# Example: https://bond-tracker.up.railway.app
APP_URL=http://localhost:5000
